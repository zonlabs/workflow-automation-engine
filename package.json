{
  "name": "workflow-automation-engine",
  "version": "0.0.1",
  "description": "Production-ready BullMQ + Node.js recipe automation engine with Supabase integration",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "ts-node worker.ts",
    "build": "npx tsc",
    "start": "node dist/worker.js",
    "worker": "ts-node worker.ts",
    "scheduler": "ts-node workers/scheduler.ts",
    "script-runner": "ts-node script-runner/server.ts",
    "mcp-server": "ts-node mcp-server/main.ts",
    "fix:workflow-step-args": "ts-node scripts/fix-workflow-step-args.ts",
    "migrate": "psql -U postgres -d postgres -f database.sql",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49",
    "@mcp-ts/sdk": "^1.3.9",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@supabase/supabase-js": "^2.38.0",
    "@vercel/sandbox": "^1.0.0",
    "ai": "^6.0.0",
    "body-parser": "^1.20.4",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "ioredis": "^5.9.3",
    "redis": "^4.6.11",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.2"
  }
}
