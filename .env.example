# ── What listens on which port (architecture) ───────────────────────────────
#
# • workflow-mcp-web (Next.js, deployed on Vercel/Railway as a *web* service)
#     HTTP: PORT (e.g. 3000 / 3001). This is your public MCP URL …/api/mcp.
#
# • npm run worker  (this package: worker.ts + BullMQ)
#     Does NOT open an HTTP port. It only connects to Redis and Supabase.
#     On Railway there is nothing to “open in browser” for the worker—no port URL.
#
# • npm run script-runner  (optional, separate terminal)
#     HTTP: WORKFLOW_SCRIPT_RUNNER_PORT (default 7071). The *worker* calls this URL
#     (WORKFLOW_SCRIPT_RUNNER_URL) when running script workflows in local mode.
#     7071 is NOT the worker; it is only the script-runner microservice.
#
# ── Redis: BullMQ “noeviction” warning ───────────────────────────────────────
# If you see: Eviction policy is volatile-lru. It should be "noeviction"
# your Redis maxmemory-policy must be noeviction (BullMQ needs jobs not evicted).
# Without redis-cli, from this repo (uses .env REDIS_URL):
#   npm run redis:set-noeviction
# Or: docker run -p 6379:6379 redis:7-alpine redis-server --maxmemory-policy noeviction
# Managed Redis often blocks CONFIG — use the Redis app's settings / parameters UI.
#
# ── Local dev (recommended) ─────────────────────────────────────────────────
# Redis: redis-server  OR  docker run -p 6379:6379 redis:7-alpine
#   Optional explicit URL (overrides REDIS_HOST/PORT below):
# REDIS_URL=redis://localhost:6379/0
#
# Database: this project uses the Supabase API, not a raw Postgres URL.
#   From repo root: supabase start
#   SUPABASE_URL=http://127.0.0.1:54321
#   Keys: copy from `supabase status` (or use default demo JWTs in Supabase local docs)

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Supabase Configuration (cloud or local API URL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-key

# MCP Credentials
MCP_CREDENTIALS_REDIS_PREFIX=mcp_creds:
MCP_SERVER_URL=http://localhost:3001

# Optional service ports (defaults shown — set only to override)
# Standalone MCP HTTP server: npm run mcp-server
# WORKFLOW_MCP_PORT=3002
# Local script-runner: npm run script-runner
# WORKFLOW_SCRIPT_RUNNER_PORT=7071
# Next workflow-mcp-web app uses PORT in workflow-mcp-web/.env (see that folder)

# Worker Configuration
WORKER_CONCURRENCY=5
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_DELAY=5000
WORKER_JOB_TIMEOUT=600000

# AI Provider Keys (at least one required for AI-powered workflow steps)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=

# AI Configuration (invoke_llm / script-runner / conditions default to this provider+model)
AI_DEFAULT_PROVIDER=deepseek
AI_DEFAULT_MODEL=deepseek-chat
AI_MAX_ITERATIONS=15
AI_MAX_TOKENS_PER_STEP=16384
AI_AGENT_TIMEOUT_MS=120000

# Application
LOG_LEVEL=info
NODE_ENV=development
