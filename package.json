{
  "name": "recipe-automation-engine",
  "version": "1.0.0",
  "description": "Production-ready BullMQ + Node.js recipe automation engine with Supabase integration",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "ts-node worker.ts",
    "build": "tsc",
    "start": "node dist/worker.js",
    "worker": "ts-node worker.ts",
    "scheduler": "ts-node workers/scheduler.ts",
    "migrate": "psql -U postgres -d postgres -f database.sql",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49",
    "@mcp-ts/sdk": "^1.3.6",
    "@supabase/supabase-js": "^2.38.0",
    "ai": "^6.0.0",
    "bullmq": "^5.0.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.9.3",
    "redis": "^4.6.11",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.2"
  }
}
